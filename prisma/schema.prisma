generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                 String              @id @default(cuid())
  name               String              @unique
  email              String
  phone              String[]
  address            String
  motto              String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  classes            Classes[]
  School             Exam[]
  expenses           Expense[]
  feeCategories      FeeCategory[]
  GlobalExamSettings GlobalExamSettings?
  GradeCriteria      GradeCriteria[]
  invoices           Invoice[]
  payments           Payment[]
  paymentGateways    PaymentGateway[]
  PsychomotorSkill   PsychomotorSkill[]
  sessions           Session[]
  fromTransfers      StudentTransfer[]   @relation("FromSchoolRelation")
  toTransfers        StudentTransfer[]   @relation("ToSchoolRelation")
  subjects           SubjectSchool[]
  timetables         Timetable[]
  userSchools        UserSchool[]
  students           Student[]
}

model UserSchool {
  id        String   @id @default(cuid())
  userId    String
  schoolId  String
  role      UserRole @default(other)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId])
}

model User {
  id                String              @id @default(cuid())
  email             String?             @unique
  username          String              @unique
  password          String
  hasVerifiedEmail  Boolean             @default(false)
  isSuperAdmin      Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  passwordChangedAt DateTime?
  notification      Notification[]
  parent            Parent?
  message           Scheduled_Message[]
  staff             Staff?
  student           Student?
  userSchools       UserSchool[]
}

model Student {
  id                           String                         @id @default(cuid())
  userId                       String                         @unique
  admission_number             String?
  schoolId                     String?
  name                         String
  gender                       Gender
  dob                          DateTime
  phone                        String?
  email                        String?
  address                      String
  admission_date               DateTime                       @default(now())
  religion                     String?
  blood_group                  String?
  father_name                  String?
  mother_name                  String?
  father_occupation            String?
  mother_occupation            String?
  isActive                     Boolean                        @default(true)
  city                         String?
  state                        String?
  country                      String?
  route_vehicle_id             String?
  room_id                      String?
  added_by                     String?
  photo_url                    String?
  isStudent                    Boolean                        @default(true)
  parentId                     String
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt
  attendance                   Attendance[]
  ExamAttempt                  ExamAttempt[]
  promotion_history            PromotionHistory[]
  Result                       Result[]
  parent                       Parent                         @relation(fields: [parentId], references: [id])
  user                         User                           @relation(fields: [userId], references: [id])
  school                       School?                        @relation(fields: [schoolId], references: [id])
  student_enrolled             StudentEnrollment[]
  studentInvoices              StudentInvoice[]
  StudentPsychomotorAssessment StudentPsychomotorAssessment[]
  student_transfer             StudentTransfer[]

  @@unique([schoolId, admission_number])
}

model Staff {
  id                           String                         @id @default(cuid())
  userId                       String                         @unique
  name                         String
  phone                        String[]
  email                        String?
  address                      String
  designation                  String?
  dob                          DateTime?
  salary                       Int?
  joining_date                 DateTime?
  gender                       Gender?
  photo_url                    String?
  isActive                     Boolean                        @default(true)
  qualification                String?
  notes                        String?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt
  attendance                   Attendance[]
  class_teacher                Class_Section[]
  timetables                   Entry[]
  Exam                         Exam[]
  Question                     Question[]
  QuestionBank                 QuestionBank[]
  user                         User                           @relation(fields: [userId], references: [id])
  StudentPsychomotorAssessment StudentPsychomotorAssessment[]
  TeacherSubjects              Subject[]
}

model Parent {
  id        String    @id @default(cuid())
  userId    String    @unique
  name      String
  phone     String?
  email     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  students  Student[]
}

model Session {
  id                           String                         @id @default(cuid())
  name                         String
  schoolId                     String
  start_date                   DateTime
  end_date                     DateTime
  isActive                     Boolean                        @default(false)
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt
  school                       School                         @relation(fields: [schoolId], references: [id])
  Exam                         Exam[]
  ExamTimetable                ExamTimetable[]
  invoices                     Invoice[]
  promotion_history            PromotionHistory[]
  student_enrolled             StudentEnrollment[]
  StudentPsychomotorAssessment StudentPsychomotorAssessment[]
  terms                        Term[]
  timetables                   Timetable[]

  @@unique([name, schoolId])
}

model Term {
  id                           String                         @id @default(cuid())
  name                         String
  sessionId                    String
  start_date                   DateTime
  end_date                     DateTime
  resumptionDate               DateTime?
  isActive                     Boolean                        @default(false)
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt
  Exam                         Exam[]
  ExamTimetable                ExamTimetable[]
  invoices                     Invoice[]
  promotion_history            PromotionHistory[]
  student_enrolled             StudentEnrollment[]
  StudentPsychomotorAssessment StudentPsychomotorAssessment[]
  session                      Session                        @relation(fields: [sessionId], references: [id])
  timetables                   Timetable[]

  @@unique([name, sessionId])
}

model Classes {
  id                           String              @id @default(cuid())
  name                         String
  schoolId                     String
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  sections                     Class_Section[]
  schools                      School              @relation(fields: [schoolId], references: [id])
  Exam                         Exam[]
  ExamTimetable                ExamTimetable[]
  from_class_promotion_history PromotionHistory[]  @relation("FromClassRelation")
  to_class_promotion_history   PromotionHistory[]  @relation("ToClassRelation")
  student_enrolled             StudentEnrollment[]
  StudentTransfer              StudentTransfer[]

  @@unique([name, schoolId])
}

model Class_Section {
  id               String              @id @default(cuid())
  name             String              @default("A")
  classId          String              @map("class_id")
  teacherId        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  attendance       Attendance[]
  classes          Classes             @relation(fields: [classId], references: [id])
  class_teacher    Staff?              @relation(fields: [teacherId], references: [id])
  Exam             Exam[]
  ExamTimetable    ExamTimetable[]
  student_enrolled StudentEnrollment[]
  StudentTransfer  StudentTransfer[]
  subjects         SubjectSection[]
  timetables       Timetable[]

  @@unique([classId, name])
}

model StudentEnrollment {
  id                 String        @id @default(cuid())
  studentId          String
  classId            String
  sectionId          String
  sessionId          String
  termId             String?
  status             EnrollStatus
  classTeacherRemark String?
  schoolHeadRemark   String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  class              Classes       @relation(fields: [classId], references: [id])
  section            Class_Section @relation(fields: [sectionId], references: [id])
  session            Session       @relation(fields: [sessionId], references: [id])
  student            Student       @relation(fields: [studentId], references: [id])
  term               Term?         @relation(fields: [termId], references: [id])
}

model PromotionHistory {
  id          String   @id @default(cuid())
  studentId   String
  fromClassId String
  toClassId   String
  sessionId   String
  termId      String?
  promotedBy  String
  createdAt   DateTime @default(now())
  fromClass   Classes  @relation("FromClassRelation", fields: [fromClassId], references: [id])
  session     Session  @relation(fields: [sessionId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])
  term        Term?    @relation(fields: [termId], references: [id])
  toClass     Classes  @relation("ToClassRelation", fields: [toClassId], references: [id])
}

model StudentTransfer {
  id             String        @id @default(cuid())
  studentId      String
  fromSchoolId   String
  toSchoolId     String
  toClassId      String
  toSectionId    String
  transferReason String?
  transferDate   DateTime      @default(now())
  createdAt      DateTime      @default(now())
  fromSchool     School        @relation("FromSchoolRelation", fields: [fromSchoolId], references: [id])
  student        Student       @relation(fields: [studentId], references: [id])
  class          Classes       @relation(fields: [toClassId], references: [id])
  toSchool       School        @relation("ToSchoolRelation", fields: [toSchoolId], references: [id])
  section        Class_Section @relation(fields: [toSectionId], references: [id])
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  title     String
  message   String
  category  NotificationCategory
  isRead    Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id])
}

model Scheduled_Message {
  id          String               @id @default(cuid())
  userId      String
  title       String
  message     String
  email       String?
  category    NotificationCategory
  type        NotificationType
  scheduledAt DateTime?
  sentAt      DateTime?
  status      MessageStatus        @default(Scheduled)
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  createdBy   User                 @relation(fields: [createdById], references: [id])
}

model Subject {
  id           String           @id @default(cuid())
  name         String
  code         String?          @db.VarChar(20)
  isActive     Boolean          @default(true)
  teacherId    String?          @db.VarChar(36)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  attendance   Attendance[]
  timetables   Entry[]
  ExamPaper    ExamPaper[]
  QuestionBank QuestionBank[]
  teacher      Staff?           @relation(fields: [teacherId], references: [id])
  schools      SubjectSchool[]
  sections     SubjectSection[]

  @@index([teacherId])
}

model SubjectSchool {
  subjectId String
  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@id([subjectId, schoolId])
}

model SubjectSection {
  subjectId String
  sectionId String
  section   Class_Section @relation(fields: [sectionId], references: [id])
  subject   Subject       @relation(fields: [subjectId], references: [id])

  @@id([subjectId, sectionId])
}

model Attendance {
  id             String           @id @default(cuid())
  date           DateTime
  month          Int
  year           Int
  status         AttendanceStatus
  notes          String?
  studentId      String?          @db.VarChar(36)
  staffId        String?          @db.VarChar(36)
  sectionId      String?          @db.VarChar(36)
  subjectId      String?          @db.VarChar(36)
  attendanceType AttendanceType
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  class_section  Class_Section?   @relation(fields: [sectionId], references: [id])
  staff          Staff?           @relation(fields: [staffId], references: [id])
  student        Student?         @relation(fields: [studentId], references: [id])
  subject        Subject?         @relation(fields: [subjectId], references: [id])

  @@index([year, month, studentId])
  @@index([year, month, staffId])
  @@index([year, month, subjectId])
}

model Entry {
  id          String     @id @default(cuid())
  timetableId String
  day         WeekDay[]
  startTime   DateTime
  endTime     DateTime
  subjectId   String?
  teacherId   String?
  type        PeriodType @default(REGULAR)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  subject     Subject?   @relation(fields: [subjectId], references: [id])
  teacher     Staff?     @relation(fields: [teacherId], references: [id])
  timetable   Timetable  @relation(fields: [timetableId], references: [id])

  @@unique([day, startTime, endTime, timetableId])
}

model Timetable {
  id        String          @id @default(cuid())
  schoolId  String
  classId   String
  sectionId String
  sessionId String
  termId    String?
  name      String
  status    TimetableStatus @default(PUBLISHED)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  entries   Entry[]
  school    School          @relation(fields: [schoolId], references: [id])
  section   Class_Section   @relation(fields: [sectionId], references: [id])
  session   Session         @relation(fields: [sessionId], references: [id])
  term      Term?           @relation(fields: [termId], references: [id])

  @@unique([schoolId, sectionId, sessionId, termId])
  @@index([sectionId, schoolId, sessionId])
}

model GlobalExamSettings {
  id                 String   @id @default(cuid())
  schoolId           String   @unique
  enablePsychomotor  Boolean  @default(false)
  showSchoolRemarks  Boolean  @default(true)
  showTeacherRemarks Boolean  @default(true)
  enablePosition     Boolean  @default(true)
  passMark           Float    @default(40)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  school             School   @relation(fields: [schoolId], references: [id])
}

model GradeCriteria {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  minScore  Float
  maxScore  Float
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, name])
}

model PsychomotorSkill {
  id          String                         @id @default(cuid())
  schoolId    String
  name        String
  description String?
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt
  school      School                         @relation(fields: [schoolId], references: [id])
  assessments StudentPsychomotorAssessment[]

  @@unique([schoolId, name])
}

model StudentPsychomotorAssessment {
  id           String           @id @default(cuid())
  studentId    String
  skillId      String
  termId       String
  sessionId    String
  rating       Int
  assessedById String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assessedBy   Staff            @relation(fields: [assessedById], references: [id])
  session      Session          @relation(fields: [sessionId], references: [id])
  skill        PsychomotorSkill @relation(fields: [skillId], references: [id])
  student      Student          @relation(fields: [studentId], references: [id])
  term         Term             @relation(fields: [termId], references: [id])

  @@unique([studentId, skillId, termId, sessionId])
}

model Exam {
  id          String         @id @default(cuid())
  title       String
  startDate   DateTime
  endDate     DateTime
  schoolId    String
  classId     String
  sectionId   String?
  termId      String
  sessionId   String
  status      ExamStatus     @default(Draft)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  class       Classes        @relation(fields: [classId], references: [id])
  createdBy   Staff?         @relation(fields: [createdById], references: [id])
  school      School         @relation(fields: [schoolId], references: [id])
  section     Class_Section? @relation(fields: [sectionId], references: [id])
  session     Session        @relation(fields: [sessionId], references: [id])
  term        Term           @relation(fields: [termId], references: [id])
  papers      ExamPaper[]
}

model ExamPaper {
  id                String         @id @default(cuid())
  examId            String
  subjectId         String
  maxMarks          Float
  paperDate         DateTime
  startTime         DateTime
  endTime           DateTime
  mode              ExamMode
  questionBankId    String?
  totalQuestions    Int?
  instructions      String?
  isResultPublished Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  attempts          ExamAttempt[]
  exam              Exam           @relation(fields: [examId], references: [id])
  questionBank      QuestionBank?  @relation(fields: [questionBankId], references: [id])
  subject           Subject        @relation(fields: [subjectId], references: [id])
  examTimetables    ExamTimetable?
  results           Result[]
}

model QuestionBank {
  id          String      @id @default(cuid())
  subjectId   String
  name        String
  description String?
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  examPapers  ExamPaper[]
  questions   Question[]
  createdBy   Staff?      @relation(fields: [createdById], references: [id])
  subject     Subject     @relation(fields: [subjectId], references: [id])

  @@unique([subjectId, name])
}

model Question {
  id            String          @id @default(cuid())
  bankId        String
  type          QuestionType
  questionText  String
  options       Json?
  correctAnswer Json?
  marks         Float
  difficulty    DifficultyLevel
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  responses     ExamResponse[]
  bank          QuestionBank    @relation(fields: [bankId], references: [id])
  createdBy     Staff?          @relation(fields: [createdById], references: [id])
}

model ExamAttempt {
  id          String         @id @default(cuid())
  examPaperId String
  studentId   String
  startedAt   DateTime?
  submittedAt DateTime?
  status      AttemptStatus  @default(NotStarted)
  totalScore  Float?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  examPaper   ExamPaper      @relation(fields: [examPaperId], references: [id])
  student     Student        @relation(fields: [studentId], references: [id])
  responses   ExamResponse[]

  @@unique([examPaperId, studentId])
}

model ExamResponse {
  id            String      @id @default(cuid())
  attemptId     String
  questionId    String
  studentAnswer Json
  isCorrect     Boolean?
  marksAwarded  Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  attempt       ExamAttempt @relation(fields: [attemptId], references: [id])
  question      Question    @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
}

model Result {
  id            String    @id @default(cuid())
  studentId     String
  examPaperId   String
  marksObtained Float
  teacherRemark String?
  isPublished   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  examPaper     ExamPaper @relation(fields: [examPaperId], references: [id])
  student       Student   @relation(fields: [studentId], references: [id])

  @@unique([studentId, examPaperId])
}

model ExamTimetable {
  id          String          @id @default(cuid())
  examPaperId String          @unique
  classId     String
  sectionId   String?
  termId      String
  sessionId   String
  status      TimetableStatus @default(DRAFT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  class       Classes         @relation(fields: [classId], references: [id])
  examPaper   ExamPaper       @relation(fields: [examPaperId], references: [id])
  section     Class_Section?  @relation(fields: [sectionId], references: [id])
  session     Session         @relation(fields: [sessionId], references: [id])
  term        Term            @relation(fields: [termId], references: [id])
}

model FeeCategory {
  id           String        @id @default(cuid())
  name         String
  description  String?
  schoolId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@unique([name, schoolId])
}

model Invoice {
  id                  String           @id @default(cuid())
  invoiceNumber       String           @unique
  title               String
  description         String?
  dueDate             DateTime?
  allowPartialPayment Boolean          @default(false)
  schoolId            String
  termId              String?
  sessionId           String?
  createdBy           String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  school              School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session             Session?         @relation(fields: [sessionId], references: [id])
  term                Term?            @relation(fields: [termId], references: [id])
  invoiceItems        InvoiceItem[]
  studentInvoices     StudentInvoice[]
}

model InvoiceItem {
  id            String      @id @default(cuid())
  invoiceId     String
  feeCategoryId String
  description   String?
  amount        Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  feeCategory   FeeCategory @relation(fields: [feeCategoryId], references: [id])
  invoice       Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model StudentInvoice {
  id          String        @id @default(cuid())
  studentId   String
  invoiceId   String
  assignedAt  DateTime      @default(now())
  assignedBy  String
  status      InvoiceStatus @default(UNPAID)
  totalAmount Float
  amountPaid  Float         @default(0)
  amountDue   Float
  payments    Payment[]
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, invoiceId])
}

model PaymentGateway {
  id          String   @id @default(cuid())
  schoolId    String
  provider    String
  publicKey   String
  secretKey   String
  webhookUrl  String?
  isActive    Boolean  @default(true)
  merchantId  String?
  callbackUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, provider])
}

model Payment {
  id               String         @id @default(cuid())
  paymentNumber    String         @unique
  studentInvoiceId String
  amount           Float
  paymentMethod    PaymentMethod
  status           PaymentStatus  @default(PENDING)
  transactionRef   String?
  gatewayResponse  Json?
  paidAt           DateTime?
  schoolId         String
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  school           School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentInvoice   StudentInvoice @relation(fields: [studentInvoiceId], references: [id])
}

model PaymentWebhook {
  id        String   @id @default(cuid())
  provider  String
  eventType String
  payload   Json
  processed Boolean  @default(false)
  paymentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  description String?
  amount      Float
  category    ExpenseCategory
  receiptUrl  String?
  expenseDate DateTime
  schoolId    String
  createdBy   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  school      School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                       String    @id @default(cuid())
  appName                  String    @default("EduStack")
  appVersion               String    @default("1.0.0")
  appDescription           String?   @default("Comprehensive School Management System")
  appLogo                  String?
  appFavicon               String?
  maintenanceMode          Boolean   @default(false)
  maintenanceMessage       String?   @default("System is under maintenance. Please try again later.")
  allowRegistration        Boolean   @default(true)
  requireEmailVerification Boolean   @default(true)
  sessionTimeout           Int       @default(3600)
  maxLoginAttempts         Int       @default(5)
  passwordMinLength        Int       @default(8)
  requireStrongPassword    Boolean   @default(true)
  maxFileSize              Int       @default(10485760)
  allowedFileTypes         String[]  @default(["jpg", "jpeg", "png", "pdf", "doc", "docx"])
  enableEmailNotifications Boolean   @default(true)
  enableSmsNotifications   Boolean   @default(false)
  enablePushNotifications  Boolean   @default(true)
  isOnboarded              Boolean   @default(false)
  onboardedAt              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@map("system_settings")
}

model OnboardingStatus {
  id                   String    @id @default(cuid())
  step1_superAdmin     Boolean   @default(false)
  step2_schoolSetup    Boolean   @default(false)
  step3_finalReview    Boolean   @default(false)
  currentStep          Int       @default(1)
  totalSteps           Int       @default(3)
  completionPercentage Float     @default(0.0)
  startedAt            DateTime  @default(now())
  completedAt          DateTime?
  lastUpdatedStep      Int?
  lastUpdatedAt        DateTime  @updatedAt
  configData           Json?

  @@map("onboarding_status")
}

model SystemLog {
  id        String         @id @default(cuid())
  level     SystemLogLevel @default(INFO)
  category  String
  message   String
  details   Json?
  userId    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime       @default(now())

  @@index([level, category, createdAt])
  @@map("system_logs")
}

