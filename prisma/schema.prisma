// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  others
}

enum EnrollStatus {
  enrolled
  promoted
  transferred
  pending
  rejected
  graduated
}

enum UserRole {
  student
  admin
  teacher
  finance
  librarian
  parent
  super_admin
  other
  edustack
}

model School {
  id            String            @id @default(cuid())
  name          String            @unique
  email         String
  phone         String[]
  address       String
  userSchools   UserSchool[]
  classes       Classes[]
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  fromTransfers StudentTransfer[] @relation("FromSchoolRelation")
  toTransfers   StudentTransfer[] @relation("ToSchoolRelation")
}

model UserSchool {
  id        String   @id @default(cuid())
  userId    String
  schoolId  String
  role      UserRole @default(other)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, schoolId])
}

model User {
  id                String              @id @default(cuid())
  email             String?             @unique
  username          String              @unique
  password          String
  userSchools       UserSchool[]
  student           Student?
  staff             Staff?
  parent            Parent?
  isSuperAdmin      Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  passwordChangedAt DateTime?
  notification      Notification[]
  message           Scheduled_Message[]
}

model Student {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  admission_number  Int?     @unique @default(autoincrement())
  name              String
  gender            Gender
  dob               DateTime
  phone             String?
  email             String?
  address           String
  admission_date    DateTime @default(now())
  religion          String?
  blood_group       String?
  father_name       String?
  mother_name       String?
  father_occupation String?
  mother_occupation String?
  isActive          Boolean  @default(true)
  city              String?
  state             String?
  country           String?
  route_vehicle_id  String?
  room_id           String?
  added_by          String?
  photo_url         String?
  isStudent         Boolean  @default(true)
  parent            Parent   @relation(fields: [parentId], references: [id])
  parentId          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student_enrolled  StudentEnrollment[]
  promotion_history PromotionHistory[]
  student_transfer  StudentTransfer[]
}

model Staff {
  id            String          @id @default(cuid())
  userId        String          @unique
  user          User            @relation(fields: [userId], references: [id])
  name          String
  phone         String[]
  email         String?
  address       String
  designation   String?
  dob           DateTime?
  salary        Int?
  joining_date  DateTime?
  gender        Gender?
  photo_url     String?
  isActive      Boolean         @default(true)
  qualification String?
  notes         String?
  class_teacher Class_Section[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Parent {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  name      String
  phone     String?
  email     String
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Session {
  id         String   @id @default(cuid())
  name     String   @unique
  start_date DateTime
  end_date   DateTime
  isActive   Boolean  @default(false)
  terms      Term[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student_enrolled  StudentEnrollment[]
  promotion_history PromotionHistory[]
}

model Term {
  id                String              @id @default(cuid())
  name            String
  sessionId         String
  session           Session             @relation(fields: [sessionId], references: [id])
  start_date        DateTime
  end_date          DateTime
  isActive          Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  student_enrolled  StudentEnrollment[]
  promotion_history PromotionHistory[]

  @@unique([name, sessionId])
}

model Classes {
  id        String   @id @default(cuid())
  name    String
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student_enrolled             StudentEnrollment[]
  from_class_promotion_history PromotionHistory[]  @relation("FromClassRelation")
  to_class_promotion_history   PromotionHistory[]  @relation("ToClassRelation")
  sections                     Class_Section[]
  schools                      School              @relation(fields: [schoolId], references: [id])
  StudentTransfer              StudentTransfer[]

  @@unique([name, schoolId])
}

model Class_Section {
  id            String   @id @default(cuid())
  name        String   @default("A")
  classId       String   @map("class_id")
  teacherId     String?
  class_teacher Staff?   @relation(fields: [teacherId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student_enrolled StudentEnrollment[]
  classes          Classes             @relation(fields: [classId], references: [id])
  StudentTransfer  StudentTransfer[]

  @@unique([classId, name])
}

model StudentEnrollment {
  id        String       @id @default(cuid())
  studentId String
  classId   String
  sectionId String
  sessionId String
  termId    String?
  status    EnrollStatus
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  student Student       @relation(fields: [studentId], references: [id])
  class   Classes       @relation(fields: [classId], references: [id])
  section Class_Section @relation(fields: [sectionId], references: [id])
  session Session       @relation(fields: [sessionId], references: [id])
  term    Term?         @relation(fields: [termId], references: [id])
}

model PromotionHistory {
  id          String   @id @default(cuid())
  studentId   String
  fromClassId String
  toClassId   String
  sessionId   String
  termId      String?
  promotedBy  String
  createdAt   DateTime @default(now())

  // Relations
  student   Student @relation(fields: [studentId], references: [id])
  fromClass Classes @relation("FromClassRelation", fields: [fromClassId], references: [id])
  toClass   Classes @relation("ToClassRelation", fields: [toClassId], references: [id])
  session   Session @relation(fields: [sessionId], references: [id])
  term      Term?   @relation(fields: [termId], references: [id])
}

model StudentTransfer {
  id             String   @id @default(cuid())
  studentId      String
  fromSchoolId   String
  toSchoolId     String
  toClassId      String
  toSectionId    String
  transferReason String?
  transferDate   DateTime @default(now())
  createdAt      DateTime @default(now())

  // Relations
  student    Student       @relation(fields: [studentId], references: [id])
  fromSchool School        @relation("FromSchoolRelation", fields: [fromSchoolId], references: [id])
  toSchool   School        @relation("ToSchoolRelation", fields: [toSchoolId], references: [id])
  class      Classes       @relation(fields: [toClassId], references: [id])
  section    Class_Section @relation(fields: [toSectionId], references: [id])
}

// MESSAGE AND NOTIFICATION

enum NotificationCategory {
  GENERAL
  ACADEMIC
  ATTENDANCE
  DISCIPLINE
  EXAM
  FEES
  HOMEWORK
  LIBRARY
  SPORTS
  EVENTS
  ANNOUNCEMENT
}

enum NotificationType {
  EMAIL
  IN_APP
  BOTH
}

enum MessageStatus {
  Scheduled
  SENT
  FAILED
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  title     String
  message   String
  category  NotificationCategory
  isRead    Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model Scheduled_Message {
  id          String               @id @default(cuid())
  userId      String
  title       String
  message     String
  email       String?
  category    NotificationCategory
  type        NotificationType
  scheduledAt DateTime?
  sentAt      DateTime?
  status      MessageStatus        @default(Scheduled)
  createdById String
  createdBy   User                 @relation(fields: [createdById], references: [id])
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}
